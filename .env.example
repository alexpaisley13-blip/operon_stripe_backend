# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Supabase example: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/operon

# ──────────────────────────────────────────────────────────────────────────────
# Stripe keys — use test keys (sk_test_...) during development
# ──────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_REDIRECT_URI=http://localhost:3000/api/stripe/callback
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────────────────────────────────────────
# HMAC secret for signing/verifying the OAuth state parameter.
# Can be any long random string. Falls back to STRIPE_SECRET_KEY if not set.
# ──────────────────────────────────────────────────────────────────────────────
STRIPE_STATE_SECRET=change_me_to_a_long_random_string

# ──────────────────────────────────────────────────────────────────────────────
# Your Operon JWT signing secret (used to verify Bearer tokens)
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_operon_jwt_secret

# ──────────────────────────────────────────────────────────────────────────────
# Public URL of your Operon frontend — users are redirected here after
# completing (or cancelling) the Stripe Connect flow
# ──────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
